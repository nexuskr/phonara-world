# ============================================================
# Phonara — 환경 변수 예시
# ============================================================
# 사용법:
#   1) 이 파일을 `.env`로 복사
#   2) 각 값을 본인 환경에 맞게 채움
#   3) `.env`는 절대 커밋하지 말 것 (.gitignore에 포함됨)
# ============================================================

# ---- Supabase / Lovable Cloud (필수) ----
# Lovable Cloud 사용 시: 자동 주입됨 (수정 불필요)
# 자체 Supabase 이전 시: 새 프로젝트의 값으로 교체
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# ---- Edge Functions Secrets (Supabase Dashboard에서 설정) ----
# 아래는 .env에 두지 않고 Supabase > Edge Functions > Secrets에 저장.
# 참고용 목록만 여기 기록.
#
# LOVABLE_API_KEY              — Lovable AI Gateway (자체 운영 시 OPENAI_API_KEY 등으로 대체)
# RESEND_API_KEY               — 트랜잭셔널/인증 이메일
# LINE_CHANNEL_ACCESS_TOKEN    — LINE 알림
# LINE_CHANNEL_SECRET          — LINE Webhook 검증
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY  — 웹 푸시
# CLOUDFLARE_R2_*              — R2 스토리지 (선택)
# SUPABASE_SERVICE_ROLE_KEY    — 서버 전용 (자동 주입, 클라이언트에 노출 금지)
